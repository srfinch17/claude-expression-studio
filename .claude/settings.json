{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_network_requests",
      "mcp__expression-studio__matrix_status",
      "mcp__expression-studio__matrix_version",
      "mcp__expression-studio__matrix_studio"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/rebuild-mcp.mjs",
            "statusMessage": "Rebuilding MCP server (if changed)…"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/rebuild-mcp.mjs",
            "statusMessage": "Checking MCP server build…"
          }
        ]
      }
    ]
  }
}
